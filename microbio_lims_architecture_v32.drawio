        <mxCell id="iio_r6_out" value="&lt;i&gt;[OUTPUT]&lt;/i&gt;&#10;&#10;enriched chunk:&#10;  chunk_id:        chunk_001&#10;  text_raw:        &quot;Slide preparation: Place...&quot;&#10;  text_enriched:   &quot;Slide preparation [Code 87209:&#10;                    Smear, primary source]: Place...&quot;&#10;  entities: {&#10;    organisms:   [&quot;Gram-positive cocci&quot;]&#10;    specimens:   [&quot;sputum&quot;, &quot;wound exudate&quot;]&#10;    instruments: [&quot;BD Phoenix&quot;]&#10;    codes:       [&quot;87209&quot;]&#10;    regs:        [&quot;CLIA §493.1252&quot;]&#10;  }&#10;  phi_detected:    false&#10;  themes:          [{G2: 0.84}, {G5: 0.41}]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="810" y="1070" width="860" height="170" as="geometry" />
        </mxCell>

        <mxCell id="iio_r7_in" value="&lt;i&gt;[INPUT]&lt;/i&gt;&#10;&#10;enriched chunks (~150)&#10;&#10;per chunk:&#10;  text_enriched +&#10;  all metadata above" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="30" y="1260" width="540" height="170" as="geometry" />
        </mxCell>
        <mxCell id="iio_r7_stage" value="&lt;b&gt;7.&lt;br&gt;EMBED&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="590" y="1260" width="200" height="170" as="geometry" />
        </mxCell>
        <mxCell id="iio_r7_out" value="&lt;i&gt;[OUTPUT]&lt;/i&gt;&#10;&#10;embedded chunk:&#10;  chunk_id: chunk_001&#10;&#10;  dense_vector:&#10;    [0.0234, -0.1849, 0.0573, ..., 0.2891]&#10;    (1024 dimensions, Bedrock Titan v2)&#10;&#10;  bm25_tokens_raw:&#10;    [&quot;slide&quot;,&quot;preparation&quot;,&quot;place&quot;,&quot;drop&quot;,&quot;specimen&quot;,...]&#10;&#10;  bm25_tokens_enriched:&#10;    [...,&quot;code&quot;,&quot;87209&quot;,&quot;smear&quot;,&quot;primary&quot;,&quot;source&quot;,...]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="810" y="1260" width="860" height="170" as="geometry" />
        </mxCell>

        <mxCell id="iio_r8_in" value="&lt;i&gt;[INPUT]&lt;/i&gt;&#10;&#10;embedded chunks (~150)&#10;+ all metadata accumulated&#10;  through stages 4-6" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="30" y="1450" width="540" height="170" as="geometry" />
        </mxCell>
        <mxCell id="iio_r8_stage" value="&lt;b&gt;8.&lt;br&gt;STORE&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="590" y="1450" width="200" height="170" as="geometry" />
        </mxCell>
        <mxCell id="iio_r8_out" value="&lt;i&gt;[OUTPUT]&lt;/i&gt;&#10;&#10;Vector index (OpenSearch k-NN):&#10;  PUT chunk_001 → {dense_vector, doc_id, section, themes}&#10;&#10;Sparse index (OpenSearch BM25):&#10;  PUT chunk_001 → {tokens_raw, tokens_enriched, doc_id, section}&#10;&#10;Chunk metadata (DynamoDB):&#10;  PUT chunk_001 → {entities, themes, version, confidence, phi_status}&#10;&#10;Doc registry: (already populated in stage 4)&#10;S3 original docs: (untouched — source of truth)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="810" y="1450" width="860" height="170" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  

<diagram name="Retrieval" id="retrieval-pipeline">
    <mxGraphModel dx="2200" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="r_title" value="Microbiology LIMS POC — Retrieval Pipeline (per query)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1100" height="34" as="geometry" />
        </mxCell>
        <mxCell id="r_subtitle" value="Query → intent decode → multi-slot hybrid retrieval → reranked, role-labeled context → generation" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="55" width="1100" height="20" as="geometry" />
        </mxCell>
        <mxCell id="r_legend" value="LEGEND&#10;&#10;■ Source / data    ■ Compute    ■ AI / LLM    ■ Storage    ■ Decision    ■ Cross-cutting" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="1180" y="20" width="490" height="60" as="geometry" />
        </mxCell>

        <mxCell id="r_lbl_input" value="1. INPUT" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="20" y="135" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="r_input_container" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#aaaaaa;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="140" y="110" width="1160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="r_input_query" value="User query" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="160" y="130" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="r_input_session" value="Session state&#10;(artifacts · drafts · refs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="420" y="130" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="r_input_config" value="Consumed config (from ingestion)&#10;8 theme centroids · theme defs · code dictionaries" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;dashed=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="720" y="130" width="580" height="50" as="geometry" />
        </mxCell>

        <mxCell id="r_lbl_pre" value="2. PRE-PROCESS" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="20" y="240" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="r_pre_norm" value="Normalize · language detect · ref extraction (e.g. &quot;epic 3&quot;, @SOP-MICRO-005)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="320" y="220" width="800" height="60" as="geometry" />
        </mxCell>

        <mxCell id="r_lbl_intent" value="3. INTENT DECODE" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="20" y="345" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="r_intent_combined" value="INTENT DECODE — three components run in parallel&#10;&#10;• Centroid similarity → soft theme distribution      • Haiku structured classifier → {action, themes, discipline, granularity, refs, confidence}      • Co-reference resolver → session refs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;verticalAlign=middle;spacingLeft=14;" vertex="1" parent="1">
          <mxGeometry x="140" y="320" width="1160" height="90" as="geometry" />
        </mxCell>

        <mxCell id="r_lbl_decision" value="DECISION" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontStyle=2;fontColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="20" y="450" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="r_intent_decision" value="Confidence ≥ τ  AND  action ∈ {generate, expand, compare, ask, edit} ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="320" y="440" width="800" height="80" as="geometry" />
        </mxCell>
        <mxCell id="r_branch_clarify" value="→ Clarifying question to user (loop)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;dashed=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1160" y="455" width="240" height="30" as="geometry" />
        </mxCell>
        <mxCell id="r_branch_session" value="→ Session-only path (recall / edit) — bypass corpus" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;dashed=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1160" y="495" width="320" height="30" as="geometry" />
        </mxCell>

        <mxCell id="r_lbl_expand" value="4. EXPAND" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="20" y="565" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="r_expand_combined" value="Query expansion&#10;paraphrase + UMLS synonyms     ·     code &amp; entity expansion (codes in query → expanded form)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="320" y="555" width="800" height="60" as="geometry" />
        </mxCell>

        <mxCell id="r_lbl_retrieve" value="5. RETRIEVE" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="20" y="725" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="r_retrieve_container" value="MULTI-SLOT HYBRID RETRIEVAL&#10;per slot: BM25 + Dense → RRF fusion → top-K candidates" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#aaaaaa;dashed=1;verticalAlign=top;fontSize=11;fontStyle=2;fontColor=#666666;align=left;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="140" y="650" width="1160" height="200" as="geometry" />
        </mxCell>
        <mxCell id="r_slot1" value="SLOT 1&#10;In-theme · target&#10;&#10;discipline = Micro&#10;theme ∈ active&#10;top 20" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="160" y="700" width="200" height="140" as="geometry" />
        </mxCell>
        <mxCell id="r_slot2" value="SLOT 2&#10;Cyto analogy&#10;&#10;discipline = Cyto&#10;theme ∈ active&#10;top 10 — adapt, don't copy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="700" width="200" height="140" as="geometry" />
        </mxCell>
        <mxCell id="r_slot3" value="SLOT 3&#10;Adjacent themes&#10;&#10;discipline = Micro&#10;theme ∈ neighbors-by-centroid&#10;top 10" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="600" y="700" width="200" height="140" as="geometry" />
        </mxCell>
        <mxCell id="r_slot4" value="SLOT 4 (cond.)&#10;Jira exemplars&#10;&#10;doc_type = jira_export&#10;only when generate ∧ epic&#10;top 5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;dashed=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="820" y="700" width="200" height="140" as="geometry" />
        </mxCell>
        <mxCell id="r_slot5" value="SLOT 5 (cond.)&#10;Regulatory / standards&#10;&#10;doc_type = regulatory&#10;only on QC / compliance themes&#10;top 3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;dashed=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1040" y="700" width="240" height="140" as="geometry" />
        </mxCell>

        <mxCell id="r_lbl_rerank" value="6. RERANK" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="20" y="885" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="r_rerank_combined" value="Cross-encoder reranker per slot (Cohere Rerank or Claude Haiku) → top-K per slot&#10;Low-score gate: all slots below θ → flag &quot;no relevant content&quot; · broaden &amp; retry · or refuse" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="870" width="1080" height="70" as="geometry" />
        </mxCell>

        <mxCell id="r_lbl_assemble" value="7. ASSEMBLE" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="20" y="975" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="r_assemble_combined" value="ASSEMBLE&#10;dedupe across slots · token-budget trim (drop low-priority slot first) · role-labeled context (PRIMARY · ANALOGY · ADJACENT · EXEMPLAR · REG)&#10;+ 8-theme prior · session context · output schema (epic / story)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="960" width="1080" height="80" as="geometry" />
        </mxCell>

        <mxCell id="r_lbl_output" value="8. OUTPUT" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="20" y="1085" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="r_output_container" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#aaaaaa;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="140" y="1070" width="1160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="r_output_gen" value="→ Generation layer (LLM call · structured output · citations resolved to S3 doc + section + version)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="160" y="1085" width="540" height="50" as="geometry" />
        </mxCell>
        <mxCell id="r_output_tel" value="→ Telemetry (query · intent · slot scores · final context · latency)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="740" y="1085" width="540" height="50" as="geometry" />
        </mxCell>

        <mxCell id="r_e_input_pre" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#444444;strokeWidth=1.5;" edge="1" parent="1" source="r_input_container" target="r_pre_norm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_pre_intent" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#444444;strokeWidth=1.5;" edge="1" parent="1" source="r_pre_norm" target="r_intent_combined">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_intent_decision" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#444444;strokeWidth=1.5;" edge="1" parent="1" source="r_intent_combined" target="r_intent_decision">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_decision_expand" value="proceed" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#444444;strokeWidth=1.5;fontSize=10;" edge="1" parent="1" source="r_intent_decision" target="r_expand_combined">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_expand_retrieve" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#444444;strokeWidth=1.5;" edge="1" parent="1" source="r_expand_combined" target="r_retrieve_container">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_retrieve_rerank" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#444444;strokeWidth=1.5;" edge="1" parent="1" source="r_retrieve_container" target="r_rerank_combined">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_rerank_assemble" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#444444;strokeWidth=1.5;" edge="1" parent="1" source="r_rerank_combined" target="r_assemble_combined">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_assemble_output" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#444444;strokeWidth=1.5;" edge="1" parent="1" source="r_assemble_combined" target="r_output_container">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_decision_clarify" value="low confidence" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#d79b00;strokeWidth=1.5;dashed=1;fontSize=10;fontColor=#d79b00;" edge="1" parent="1" source="r_intent_decision" target="r_branch_clarify">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_decision_session" value="recall / edit" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.7;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#d79b00;strokeWidth=1.5;dashed=1;fontSize=10;fontColor=#d79b00;" edge="1" parent="1" source="r_intent_decision" target="r_branch_session">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  

<diagram name="Retrieval I/O" id="retrieval-io">
    <mxGraphModel dx="2200" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="rio_title" value="Retrieval — Stage I/O Examples" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="34" as="geometry" />
        </mxCell>
        <mxCell id="rio_subtitle" value="What each stage receives → what it produces, with concrete data examples" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="55" width="1100" height="20" as="geometry" />
        </mxCell>
        <mxCell id="rio_note" value="Example traces one query: &quot;Generate epics for specimen rejection in microbiology&quot;&#10;Output of stage N = input of stage N+1." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=10;align=left;verticalAlign=middle;fontStyle=2;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1180" y="25" width="490" height="50" as="geometry" />
        </mxCell>

        <mxCell id="rio_r1_in" value="&lt;i&gt;[INPUT]&lt;/i&gt;&#10;&#10;SME types in chat:&#10;&#10;  &quot;Generate epics for specimen&#10;   rejection in microbiology&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="30" y="120" width="540" height="170" as="geometry" />
        </mxCell>
        <mxCell id="rio_r1_stage" value="&lt;b&gt;1.&lt;br&gt;INPUT&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="590" y="120" width="200" height="170" as="geometry" />
        </mxCell>
        <mxCell id="rio_r1_out" value="&lt;i&gt;[OUTPUT]&lt;/i&gt;&#10;&#10;{&#10;  user_query: &quot;Generate epics for specimen rejection&#10;              in microbiology&quot;&#10;  session_state: {&#10;    drafts: [{id:1, title:&quot;Specimen Rejection...&quot;},&#10;             {id:2, title:&quot;AST Workflow&quot;}]&#10;    prior_turns: [...]&#10;  }&#10;  consumed_config: {&#10;    theme_centroids: [&lt;8 vectors&gt;],&#10;    theme_defs:      [...],&#10;    code_dict:       [...]&#10;  }&#10;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="810" y="120" width="860" height="170" as="geometry" />
        </mxCell>

        <mxCell id="rio_r2_in" value="&lt;i&gt;[INPUT]&lt;/i&gt;&#10;&#10;raw user query string&#10;+ session state" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="30" y="310" width="540" height="170" as="geometry" />
        </mxCell>
        <mxCell id="rio_r2_stage" value="&lt;b&gt;2.&lt;br&gt;PRE-PROCESS&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="590" y="310" width="200" height="170" as="geometry" />
        </mxCell>
        <mxCell id="rio_r2_out" value="&lt;i&gt;[OUTPUT]&lt;/i&gt;&#10;&#10;{&#10;  normalized_query: &quot;Generate epics for specimen&#10;                    rejection in microbiology&quot;,&#10;  language: &quot;en&quot;,&#10;  refs: []&#10;    (no '@SOP-...' or 'epic N' patterns detected)&#10;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="810" y="310" width="860" height="170" as="geometry" />
        </mxCell>

        <mxCell id="rio_r3_in" value="&lt;i&gt;[INPUT]&lt;/i&gt;&#10;&#10;normalized query&#10;+ session state&#10;+ config (8 theme centroids)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="30" y="500" width="540" height="170" as="geometry" />
        </mxCell>
        <mxCell id="rio_r3_stage" value="&lt;b&gt;3.&lt;br&gt;INTENT&lt;br&gt;DECODE&lt;br&gt;+ DECISION&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="590" y="500" width="200" height="170" as="geometry" />
        </mxCell>
        <mxCell id="rio_r3_out" value="&lt;i&gt;[OUTPUT]&lt;/i&gt;&#10;&#10;Centroid distribution (no LLM):&#10;  G1: 0.81  G5: 0.18  G2: 0.04  others: &lt; 0.02&#10;&#10;Haiku classifier:&#10;  action: generate     themes: [G1, G5]&#10;  discipline: Micro    granularity: epic&#10;  refs: []             confidence: 0.91&#10;&#10;Co-ref resolved: []&#10;&#10;Decision: PROCEED → expand&#10;  (conf 0.91 ≥ τ=0.7  ✓   action ∈ corpus_actions  ✓)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="810" y="500" width="860" height="170" as="geometry" />
        </mxCell>

        <mxCell id="rio_r4_in" value="&lt;i&gt;[INPUT]&lt;/i&gt;&#10;&#10;intent {action, themes, discipline,&#10;        granularity, refs, confidence}&#10;+ original query" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="30" y="690" width="540" height="170" as="geometry" />
        </mxCell>
        <mxCell id="rio_r4_stage" value="&lt;b&gt;4.&lt;br&gt;EXPAND&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="590" y="690" width="200" height="170" as="geometry" />
        </mxCell>
        <mxCell id="rio_r4_out" value="&lt;i&gt;[OUTPUT]&lt;/i&gt;&#10;&#10;{&#10;  original: &quot;specimen rejection in microbiology&quot;,&#10;&#10;  paraphrases: [&#10;    &quot;unacceptable specimens for Micro&quot;,&#10;    &quot;specimen integrity failures Micro&quot;,&#10;    &quot;specimen NDR microbiology&quot;&#10;  ],&#10;&#10;  code_expansions: []&#10;    (no codes found in query)&#10;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="810" y="690" width="860" height="170" as="geometry" />
        </mxCell>

        <mxCell id="rio_r5_in" value="&lt;i&gt;[INPUT]&lt;/i&gt;&#10;&#10;expanded query set&#10;+ active themes [G1, G5]&#10;+ discipline = Microbiology&#10;+ granularity = epic" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="30" y="880" width="540" height="170" as="geometry" />
        </mxCell>
        <mxCell id="rio_r5_stage" value="&lt;b&gt;5.&lt;br&gt;RETRIEVE&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="590" y="880" width="200" height="170" as="geometry" />
        </mxCell>
        <mxCell id="rio_r5_out" value="&lt;i&gt;[OUTPUT]&lt;/i&gt;&#10;&#10;Per slot (BM25 + Dense → RRF fusion):&#10;&#10;  slot_1 (Micro / G1+G5):     20 chunks&#10;  slot_2 (Cyto / G1+G5):      10 chunks  ← analogy&#10;  slot_3 (Micro / adjacent):  10 chunks  ← G2 neighbors&#10;  slot_4 (Jira exemplars):     5 chunks  (active: generate∧epic)&#10;  slot_5 (Regulatory):         3 chunks  (active: theme G5)&#10;&#10;  total: 48 candidate chunks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="810" y="880" width="860" height="170" as="geometry" />
        </mxCell>

        <mxCell id="rio_r6_in" value="&lt;i&gt;[INPUT]&lt;/i&gt;&#10;&#10;48 candidate chunks&#10;in 5 slots" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="30" y="1070" width="540" height="170" as="geometry" />
        </mxCell>
        <mxCell id="rio_r6_stage" value="&lt;b&gt;6.&lt;br&gt;RERANK&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="590" y="1070" width="200" height="170" as="geometry" />
        </mxCell>
        <mxCell id="rio_r6_out" value="&lt;i&gt;[OUTPUT]&lt;/i&gt;&#10;&#10;Reranked &amp;amp; trimmed (cross-encoder per slot):&#10;&#10;  slot_1: 8 chunks  (scores 0.91 → 0.62)&#10;  slot_2: 4 chunks  (scores 0.85 → 0.58)&#10;  slot_3: 3 chunks  (scores 0.72 → 0.55)&#10;  slot_4: 3 chunks  (scores 0.79 → 0.61)&#10;  slot_5: 2 chunks  (scores 0.76 → 0.59)&#10;&#10;  Low-score gate: PASS&#10;    (all slots have hits ≥ θ=0.50)&#10;&#10;  total: 20 chunks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="810" y="1070" width="860" height="170" as="geometry" />
        </mxCell>

        <mxCell id="rio_r7_in" value="&lt;i&gt;[INPUT]&lt;/i&gt;&#10;&#10;20 reranked chunks (per slot)&#10;+ session state&#10;+ output schema&#10;+ 8-theme prior" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="30" y="1260" width="540" height="170" as="geometry" />
        </mxCell>
        <mxCell id="rio_r7_stage" value="&lt;b&gt;7.&lt;br&gt;ASSEMBLE&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="590" y="1260" width="200" height="170" as="geometry" />
        </mxCell>
        <mxCell id="rio_r7_out" value="&lt;i&gt;[OUTPUT]&lt;/i&gt;&#10;&#10;Final prompt (token_count: 6,840):&#10;&#10;  SYSTEM: You generate Microbiology LIMS Jira epics.&#10;  The 8 themes: G1 Pre-Analytic ... G8 Platform.&#10;&#10;  PRIMARY:  &lt;8 Micro chunks&gt;&#10;  ANALOGY:  &lt;4 Cyto chunks&gt;&#10;  ADJACENT: &lt;3 G2 chunks&gt;&#10;  EXEMPLAR: &lt;3 Cyto epic samples&gt;&#10;  REG:      &lt;2 CLSI sections&gt;&#10;&#10;  SESSION:  &lt;existing drafts&gt;&#10;  SCHEMA:   {epics:[{title,theme,ac,stories[]}]}&#10;&#10;  USER: Generate epics for specimen rejection in microbiology" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="810" y="1260" width="860" height="170" as="geometry" />
        </mxCell>

        <mxCell id="rio_r8_in" value="&lt;i&gt;[INPUT]&lt;/i&gt;&#10;&#10;final prompt&#10;→ Bedrock Claude&#10;   (with structured-output schema)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="30" y="1450" width="540" height="170" as="geometry" />
        </mxCell>
        <mxCell id="rio_r8_stage" value="&lt;b&gt;8.&lt;br&gt;OUTPUT&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="590" y="1450" width="200" height="170" as="geometry" />
        </mxCell>
        <mxCell id="rio_r8_out" value="&lt;i&gt;[OUTPUT]&lt;/i&gt;&#10;&#10;Generated epics (JSON):&#10;[&#10;  {&#10;    epic_id:  epic_draft_3,&#10;    title:    &quot;Specimen Rejection Workflow&quot;,&#10;    theme:    G1,&#10;    citations: [&quot;s3://...SOP-MICRO-007 §AC&quot;,&#10;                &quot;s3://...SOP-CYTO-021 §Procedure&quot;,&#10;                &quot;CLSI M22 §3.4&quot;],&#10;    stories: [&quot;Validate transport temperature&quot;,&#10;              &quot;Flag specimens older than 4h&quot;, ...]&#10;  },&#10;  ... 1-3 more epics&#10;]&#10;&#10;Telemetry: query_id, intent, slot_scores, total_chunks: 20,&#10;           tokens: 6840, latency_ms: 4320" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="810" y="1450" width="860" height="170" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  

<diagram name="Query Taxonomy" id="query-taxonomy">
    <mxGraphModel dx="2200" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="qt_title" value="Query Taxonomy &amp; Routing" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="34" as="geometry" />
        </mxCell>
        <mxCell id="qt_subtitle" value="How the system handles different query shapes — explicit policies for ambiguity, defaults, and out-of-scope" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="55" width="1100" height="20" as="geometry" />
        </mxCell>
        <mxCell id="qt_note" value="Intent decoder is a 4-dim dispatcher: {action, themes, discipline, granularity}.&#10;Any combination is valid input; routing decisions below cover the variations." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=10;align=left;verticalAlign=middle;fontStyle=2;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1180" y="25" width="490" height="50" as="geometry" />
        </mxCell>

        <mxCell id="qt_sec_a" value="POLICY DECISIONS — explicit, tunable, made once with SME" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="900" height="30" as="geometry" />
        </mxCell>

        <mxCell id="qt_p1" value="&lt;b&gt;P1 — DEFAULT DISCIPLINE&lt;/b&gt;&#10;&lt;i&gt;When discipline is unspecified&lt;/i&gt;&#10;&#10;Default to &lt;b&gt;active POC discipline&lt;/b&gt; (currently Microbiology). Tag the output with 'scope: Micro'. SME can override with explicit discipline in next turn." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="140" width="380" height="140" as="geometry" />
        </mxCell>
        <mxCell id="qt_p2" value="&lt;b&gt;P2 — OUT-OF-CORPUS&lt;/b&gt;&#10;&lt;i&gt;When discipline isn't in the indexed corpus&lt;/i&gt;&#10;&#10;&lt;b&gt;Refuse to hallucinate.&lt;/b&gt; Respond with 3 options: (a) upload SOPs for that discipline, (b) draft from analogy with caveat, (c) clarify scope. Triggered by low-score gate (all slot scores &amp;lt; θ)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="440" y="140" width="380" height="140" as="geometry" />
        </mxCell>
        <mxCell id="qt_p3" value="&lt;b&gt;P3 — VAGUE QUERY&lt;/b&gt;&#10;&lt;i&gt;When intent confidence is below τ&lt;/i&gt;&#10;&#10;Don't retrieve. Ask a structured clarifying question with concrete options: pick a theme (G1–G8), pick a discipline, or request an overview. Loop the user response back through intent decode." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="840" y="140" width="380" height="140" as="geometry" />
        </mxCell>
        <mxCell id="qt_p4" value="&lt;b&gt;P4 — THRESHOLDS&lt;/b&gt;&#10;&lt;i&gt;Tunable from telemetry&lt;/i&gt;&#10;&#10;&lt;b&gt;τ (tau) = 0.7&lt;/b&gt; — intent confidence; below = clarify.&#10;&lt;b&gt;θ (theta) = 0.5&lt;/b&gt; — retrieval relevance; all slots below = refuse.&#10;Adjust quarterly from real query distribution + SME feedback." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1240" y="140" width="380" height="140" as="geometry" />
        </mxCell>

        <mxCell id="qt_sec_b" value="QUERY TAXONOMY — six query shapes and how each is handled" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="305" width="1100" height="30" as="geometry" />
        </mxCell>

        <mxCell id="qt_h_shape" value="SHAPE" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#cccccc;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="345" width="200" height="35" as="geometry" />
        </mxCell>
        <mxCell id="qt_h_query" value="EXAMPLE QUERY" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#cccccc;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="260" y="345" width="320" height="35" as="geometry" />
        </mxCell>
        <mxCell id="qt_h_intent" value="INTENT DECODE → DECISION" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#cccccc;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="600" y="345" width="500" height="35" as="geometry" />
        </mxCell>
        <mxCell id="qt_h_effect" value="EFFECT — what the user gets" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#cccccc;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1120" y="345" width="540" height="35" as="geometry" />
        </mxCell>

        <mxCell id="qt_r1_shape" value="&lt;b&gt;SPECIFIC&lt;/b&gt;&#10;&#10;&lt;i&gt;theme + discipline both clear&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="395" width="200" height="160" as="geometry" />
        </mxCell>
        <mxCell id="qt_r1_query" value="&quot;epics for specimen rejection in microbiology&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#cccccc;fontSize=11;fontStyle=2;align=left;verticalAlign=middle;spacingLeft=12;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="260" y="395" width="320" height="160" as="geometry" />
        </mxCell>
        <mxCell id="qt_r1_intent" value="action:      generate&#10;themes:      [G1]&#10;discipline:  Microbiology&#10;granularity: epic&#10;conf:        0.91&#10;&#10;Decision: PROCEED (happy path)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#cccccc;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="600" y="395" width="500" height="160" as="geometry" />
        </mxCell>
        <mxCell id="qt_r1_effect" value="• Multi-slot retrieval (all 5 slots active)&#10;• 2–4 G1 epics generated for Micro&#10;• Citations to e.g. SOP-MICRO-007 §AC,&#10;  SOP-CYTO-021 §Procedure (analogy)&#10;• Output: epics with stories + ACs&#10;• Telemetry logged" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#cccccc;fontSize=10;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1120" y="395" width="540" height="160" as="geometry" />
        </mxCell>

        <mxCell id="qt_r2_shape" value="&lt;b&gt;THEME ONLY&lt;/b&gt;&#10;&#10;&lt;i&gt;discipline unspecified&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="570" width="200" height="160" as="geometry" />
        </mxCell>
        <mxCell id="qt_r2_query" value="&quot;create epics for instrumentation&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#cccccc;fontSize=11;fontStyle=2;align=left;verticalAlign=middle;spacingLeft=12;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="260" y="570" width="320" height="160" as="geometry" />
        </mxCell>
        <mxCell id="qt_r2_intent" value="action:      generate&#10;themes:      [G7]&#10;discipline:  &lt;UNSPECIFIED&gt;&#10;granularity: epic&#10;conf:        0.92 / 0.45 (split)&#10;&#10;Decision: P1 → default to Micro&#10;          (POC active discipline)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#cccccc;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="600" y="570" width="500" height="160" as="geometry" />
        </mxCell>
        <mxCell id="qt_r2_effect" value="• Multi-slot retrieve, scope = Micro&#10;• 3–6 G7 epics: BD Phoenix integration,&#10;  MALDI-TOF workflow, MGIT 960 result&#10;  capture, instrument QC daily run, ...&#10;• Output tagged: &quot;scope: Microbiology&quot;&#10;• G7 expansion hint (6–10 instruments vs 1&#10;  in Cyto) is in the system prompt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#cccccc;fontSize=10;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1120" y="570" width="540" height="160" as="geometry" />
        </mxCell>

        <mxCell id="qt_r3_shape" value="&lt;b&gt;DISCIPLINE ONLY&lt;/b&gt;&#10;&#10;&lt;i&gt;theme unspecified — broad ask&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="745" width="200" height="160" as="geometry" />
        </mxCell>
        <mxCell id="qt_r3_query" value="&quot;create epics for microbiology&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#cccccc;fontSize=11;fontStyle=2;align=left;verticalAlign=middle;spacingLeft=12;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="260" y="745" width="320" height="160" as="geometry" />
        </mxCell>
        <mxCell id="qt_r3_intent" value="action:      generate&#10;themes:      [all G1–G8]&#10;discipline:  Microbiology&#10;granularity: epic&#10;conf:        0.88&#10;&#10;Decision: PROCEED with theme-&#10;          decomposed planner" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#cccccc;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="600" y="745" width="500" height="160" as="geometry" />
        </mxCell>
        <mxCell id="qt_r3_effect" value="• 8 retrieval+generation passes&#10;  (one per theme G1–G8)&#10;• Each pass: 2–5 epics&#10;• Final draft: ~20–40 epics across themes&#10;• Coverage check: every theme has ≥ 1 epic&#10;• Theme imbalance flagged if any (e.g.,&#10;  too much G8 platform boilerplate)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#cccccc;fontSize=10;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1120" y="745" width="540" height="160" as="geometry" />
        </mxCell>

        <mxCell id="qt_r4_shape" value="&lt;b&gt;OUT-OF-CORPUS&lt;/b&gt;&#10;&#10;&lt;i&gt;discipline absent from corpus&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="920" width="200" height="160" as="geometry" />
        </mxCell>
        <mxCell id="qt_r4_query" value="&quot;create epics for blood tests&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#cccccc;fontSize=11;fontStyle=2;align=left;verticalAlign=middle;spacingLeft=12;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="260" y="920" width="320" height="160" as="geometry" />
        </mxCell>
        <mxCell id="qt_r4_intent" value="action:      generate&#10;themes:      [G2, G5]&#10;discipline:  Chemistry / Hematology&#10;conf:        0.71 / 0.34 (split)&#10;&#10;Decision: P2 → low-score gate fires&#10;          (all slot scores &amp;lt; θ=0.50)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#cccccc;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="600" y="920" width="500" height="160" as="geometry" />
        </mxCell>
        <mxCell id="qt_r4_effect" value="P2 — REFUSE TO HALLUCINATE.&#10;Response to user:&#10;&#10;  &quot;I don't have source material for blood&#10;   tests. Current scope: Cyto + Micro.&#10;   Options:&#10;     1. Upload Hema/Chem SOPs to S3&#10;     2. Draft from Cyto/Micro analogy (caveat)&#10;     3. Clarify scope.&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#cccccc;fontSize=10;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1120" y="920" width="540" height="160" as="geometry" />
        </mxCell>

        <mxCell id="qt_r5_shape" value="&lt;b&gt;VAGUE&lt;/b&gt;&#10;&#10;&lt;i&gt;intent below confidence threshold&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="1095" width="200" height="160" as="geometry" />
        </mxCell>
        <mxCell id="qt_r5_query" value="&quot;what should we build?&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#cccccc;fontSize=11;fontStyle=2;align=left;verticalAlign=middle;spacingLeft=12;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="260" y="1095" width="320" height="160" as="geometry" />
        </mxCell>
        <mxCell id="qt_r5_intent" value="action:      ?  (unclear)&#10;themes:      []&#10;discipline:  ?&#10;conf:        0.22  (BELOW τ=0.7)&#10;&#10;Decision: P3 → clarifying question&#10;          (don't retrieve, don't generate)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#cccccc;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="600" y="1095" width="500" height="160" as="geometry" />
        </mxCell>
        <mxCell id="qt_r5_effect" value="P3 — DON'T RETRIEVE. Ask:&#10;&#10;  &quot;Which would you like to focus on?&#10;   • A theme — G1 Pre-Analytic, G2 Analytic,&#10;     ... G8 Platform&#10;   • A discipline — Microbiology (POC)&#10;   • Overview of all themes for Micro&quot;&#10;&#10;User response loops back to intent decode." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#cccccc;fontSize=10;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1120" y="1095" width="540" height="160" as="geometry" />
        </mxCell>

        <mxCell id="qt_r6_shape" value="&lt;b&gt;COMPARE&lt;/b&gt;&#10;&#10;&lt;i&gt;different action: cross-discipline&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="1270" width="200" height="160" as="geometry" />
        </mxCell>
        <mxCell id="qt_r6_query" value="&quot;compare specimen rejection between micro and cyto&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#cccccc;fontSize=11;fontStyle=2;align=left;verticalAlign=middle;spacingLeft=12;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="260" y="1270" width="320" height="160" as="geometry" />
        </mxCell>
        <mxCell id="qt_r6_intent" value="action:      compare  ← different action&#10;themes:      [G1]&#10;discipline:  cross&#10;granularity: NA&#10;conf:        0.93&#10;&#10;Decision: PROCEED in compare-mode&#10;          (different orchestration path)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#cccccc;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="600" y="1270" width="500" height="160" as="geometry" />
        </mxCell>
        <mxCell id="qt_r6_effect" value="• Compare-mode retrieval: Micro slot + Cyto&#10;  slot side-by-side (no analogy / exemplar)&#10;• Compare-mode prompt template:&#10;    SHARED / MICRO-ONLY / CYTO-ONLY /&#10;    WHY-DIVERGE&#10;• Output: comparison report,&#10;  NOT new epics&#10;• Useful for SME alignment review" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#cccccc;fontSize=10;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1120" y="1270" width="540" height="160" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  

<diagram name="Concepts &amp; AWS" id="concepts-aws">
    <mxGraphModel dx="2200" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="g_title" value="Reference — Concepts &amp; AWS Services" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1100" height="34" as="geometry" />
        </mxCell>
        <mxCell id="g_subtitle" value="Glossary of jargon used across the Ingestion and Retrieval diagrams" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="55" width="1100" height="20" as="geometry" />
        </mxCell>

        <mxCell id="g_sec1" value="ML / RETRIEVAL CONCEPTS" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="105" width="600" height="30" as="geometry" />
        </mxCell>

        <mxCell id="c_dense" value="&lt;b&gt;Dense embedding&lt;/b&gt;&#10;&#10;Text → list of 1024 numbers; similar meaning = similar numbers.&#10;&#10;&lt;i&gt;Ex: 'specimen rejection' &amp;amp; 'what gets bounced at intake' → similar vectors&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="150" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_bm25" value="&lt;b&gt;BM25 / Sparse retrieval&lt;/b&gt;&#10;&#10;Word-by-word scoring; ranks by exact word matches weighted by rarity.&#10;&#10;&lt;i&gt;Ex: catches 'C50.911' or 'Mycobacterium tuberculosis' exactly&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="150" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_hybrid" value="&lt;b&gt;Hybrid retrieval&lt;/b&gt;&#10;&#10;Run BM25 + dense in parallel, merge results.&#10;&#10;&lt;i&gt;Ex: sparse catches 'C50.911', dense catches 'workflow concept'&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="150" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_rrf" value="&lt;b&gt;RRF (Reciprocal Rank Fusion)&lt;/b&gt;&#10;&#10;Merges two ranked lists by RANK, not score. Robust without tuning.&#10;&#10;&lt;i&gt;Ex: rank 2 in BM25 + rank 3 in dense → 1/62 + 1/63&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1160" y="150" width="280" height="140" as="geometry" />
        </mxCell>

        <mxCell id="c_knn" value="&lt;b&gt;Vector index / k-NN&lt;/b&gt;&#10;&#10;Database that returns the K nearest embeddings to a query.&#10;&#10;&lt;i&gt;Ex: OpenSearch returns top 10 nearest chunks in &amp;lt;100ms&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="310" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_cosine" value="&lt;b&gt;Cosine similarity&lt;/b&gt;&#10;&#10;Score 1.0 = identical, 0 = unrelated. Standard yardstick for dense embeddings.&#10;&#10;&lt;i&gt;Ex: query cosine 0.81 with G1 centroid → query is mostly G1 theme&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="310" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_xenc" value="&lt;b&gt;Cross-encoder reranker&lt;/b&gt;&#10;&#10;Slower but more accurate per-pair scorer; the one component that handles negation well.&#10;&#10;&lt;i&gt;Ex: distinguishes 'rejected if NOT refrigerated' from 'accepted'&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="310" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_centroid" value="&lt;b&gt;Centroid (theme centroid)&lt;/b&gt;&#10;&#10;Average embedding representing a group.&#10;&#10;&lt;i&gt;Ex: G1 centroid = average of theme description + a few exemplar phrases for G1&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1160" y="310" width="280" height="140" as="geometry" />
        </mxCell>

        <mxCell id="c_rag" value="&lt;b&gt;RAG&lt;/b&gt;&#10;Retrieval-Augmented Generation&#10;&#10;Retrieve relevant chunks, add to prompt, generate.&#10;&#10;&lt;i&gt;Ex: query → 8 chunks → LLM produces grounded answer with citations&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="470" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_chunking" value="&lt;b&gt;Chunking&lt;/b&gt;&#10;&#10;Split docs into 200–500 token pieces for indexing. Structure-aware = respects sections, tables, numbered steps.&#10;&#10;&lt;i&gt;Ex: a 50-page SOP → ~150 chunks, each retrievable&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="470" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_multilabel" value="&lt;b&gt;Multi-label classification&lt;/b&gt;&#10;&#10;Each item can have multiple labels with confidence scores.&#10;&#10;&lt;i&gt;Ex: 'analyzer QC procedure' → {G5: 0.85, G7: 0.72} (Quality + Instrumentation)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="470" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_ner" value="&lt;b&gt;NER&lt;/b&gt;&#10;Named Entity Recognition&#10;&#10;Extract structured entities from text → faceted metadata.&#10;&#10;&lt;i&gt;Ex: 'M. tuberculosis treated with rifampin' → {organism, drug}&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1160" y="470" width="280" height="140" as="geometry" />
        </mxCell>

        <mxCell id="c_umls" value="&lt;b&gt;UMLS&lt;/b&gt;&#10;Unified Medical Language System&#10;&#10;NIH's master dictionary of clinical codes &amp;amp; terminology.&#10;&#10;&lt;i&gt;Ex: 'C50.911' → 'malignant neoplasm of nipple/areola, right female breast'&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="630" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_phi" value="&lt;b&gt;PHI&lt;/b&gt;&#10;Protected Health Information&#10;&#10;Patient-identifiable info. Must be redacted before indexing.&#10;&#10;&lt;i&gt;Ex: 'Patient John Smith, MRN 123456' → 'Patient [NAME], MRN [MRN]'&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="630" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_idempotent" value="&lt;b&gt;Idempotent&lt;/b&gt;&#10;&#10;Doing twice = doing once; no duplication.&#10;&#10;&lt;i&gt;Ex: re-uploading the same SOP is detected via content hash and skipped&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="630" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_dlq" value="&lt;b&gt;DLQ&lt;/b&gt;&#10;Dead-Letter Queue&#10;&#10;Holding pen for failed messages; for human review.&#10;&#10;&lt;i&gt;Ex: encrypted PDF that won't parse → DLQ instead of pipeline crash&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1160" y="630" width="280" height="140" as="geometry" />
        </mxCell>

        <mxCell id="g_sec2" value="AWS SERVICES" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="800" width="600" height="30" as="geometry" />
        </mxCell>

        <mxCell id="a_s3" value="&lt;b&gt;S3&lt;/b&gt;&#10;Simple Storage Service&#10;&#10;Object storage. Where SOPs &amp;amp; original docs live.&#10;&#10;&lt;i&gt;Ex: s3://lab-sops/micro/SOP-MICRO-014_v3.pdf&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="840" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="a_sqs" value="&lt;b&gt;SQS&lt;/b&gt;&#10;Simple Queue Service&#10;&#10;Managed message queue. Buffers ingestion bursts; auto-retry.&#10;&#10;&lt;i&gt;Ex: 50 docs uploaded at once → queued, workers drain&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="840" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="a_dynamo" value="&lt;b&gt;DynamoDB&lt;/b&gt;&#10;&#10;Managed NoSQL DB. Fast key-value / document storage.&#10;&#10;&lt;i&gt;Ex: chunk metadata table — millions of rows, low-latency reads&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="840" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="a_opensearch" value="&lt;b&gt;OpenSearch&lt;/b&gt;&#10;&#10;Search engine; supports BOTH BM25 and k-NN vector search natively.&#10;&#10;&lt;i&gt;One service for sparse + dense indexes&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1160" y="840" width="280" height="140" as="geometry" />
        </mxCell>

        <mxCell id="a_bedrock" value="&lt;b&gt;Bedrock&lt;/b&gt;&#10;&#10;Managed LLM access — Claude, Titan embeddings, Cohere embed/rerank. IAM-authed; data stays in your AWS account.&#10;&#10;&lt;i&gt;Used here for: classification, NER, theme tagging, embeddings, generation&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="1000" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="a_comprehend" value="&lt;b&gt;Comprehend Medical&lt;/b&gt;&#10;&#10;Managed clinical NER + PHI detection. Pre-trained on medical text.&#10;&#10;&lt;i&gt;Ex: extracts organisms, drugs, conditions, PHI from chunks&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="1000" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="a_textract" value="&lt;b&gt;Textract&lt;/b&gt;&#10;&#10;Managed OCR for scanned PDFs and forms. Preserves table layout.&#10;&#10;&lt;i&gt;Ex: reads scanned bench forms; pulls table structure&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="1000" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="a_lambda" value="&lt;b&gt;Lambda&lt;/b&gt;&#10;&#10;Run code on events without managing servers.&#10;&#10;&lt;i&gt;Ex: triggered by S3 PutObject to start ingestion processing&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1160" y="1000" width="280" height="140" as="geometry" />
        </mxCell>

        <mxCell id="a_iam" value="&lt;b&gt;IAM&lt;/b&gt;&#10;Identity and Access Management&#10;&#10;Controls who can do what; least-privilege scoping.&#10;&#10;&lt;i&gt;Ex: only ingestion service can write to chunk-metadata table&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="1160" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="a_kms" value="&lt;b&gt;KMS&lt;/b&gt;&#10;Key Management Service&#10;&#10;Encryption keys you control.&#10;&#10;&lt;i&gt;Ex: all S3 / DynamoDB / OpenSearch encrypted with KMS keys&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="1160" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="a_vpc" value="&lt;b&gt;VPC endpoints&lt;/b&gt;&#10;&#10;Private network paths to AWS services — traffic doesn't traverse the public internet.&#10;&#10;&lt;i&gt;Ex: Bedrock calls stay inside your AWS network&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="1160" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="a_cw" value="&lt;b&gt;CloudWatch&lt;/b&gt;&#10;&#10;Metrics, logs, alarms across all services.&#10;&#10;&lt;i&gt;Ex: alert when OCR failure rate spikes above 5%&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1160" y="1160" width="280" height="140" as="geometry" />
        </mxCell>

        <mxCell id="a_ct" value="&lt;b&gt;CloudTrail&lt;/b&gt;&#10;&#10;Audit log of every AWS API call — who did what, when.&#10;&#10;&lt;i&gt;Ex: records who read which doc when — required for compliance&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="1320" width="280" height="140" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
