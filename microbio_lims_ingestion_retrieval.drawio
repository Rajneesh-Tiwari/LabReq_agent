        </mxCell>

        <mxCell id="r_lbl_pre" value="2. PRE-PROCESS" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="20" y="240" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="r_pre_norm" value="Normalize · language detect · ref extraction (e.g. &quot;epic 3&quot;, @SOP-MICRO-005)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="320" y="220" width="800" height="60" as="geometry" />
        </mxCell>

        <mxCell id="r_lbl_intent" value="3. INTENT DECODE" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="20" y="345" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="r_intent_combined" value="INTENT DECODE — three components run in parallel&#10;&#10;• Centroid similarity → soft theme distribution      • Haiku structured classifier → {action, themes, discipline, granularity, refs, confidence}      • Co-reference resolver → session refs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;verticalAlign=middle;spacingLeft=14;" vertex="1" parent="1">
          <mxGeometry x="140" y="320" width="1160" height="90" as="geometry" />
        </mxCell>

        <mxCell id="r_lbl_decision" value="DECISION" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontStyle=2;fontColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="20" y="450" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="r_intent_decision" value="Confidence ≥ τ  AND  action ∈ {generate, expand, compare, ask, edit} ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="320" y="440" width="800" height="80" as="geometry" />
        </mxCell>
        <mxCell id="r_branch_clarify" value="→ Clarifying question to user (loop)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;dashed=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1160" y="455" width="240" height="30" as="geometry" />
        </mxCell>
        <mxCell id="r_branch_session" value="→ Session-only path (recall / edit) — bypass corpus" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;dashed=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1160" y="495" width="320" height="30" as="geometry" />
        </mxCell>

        <mxCell id="r_lbl_expand" value="4. EXPAND" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="20" y="565" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="r_expand_combined" value="Query expansion&#10;paraphrase + UMLS synonyms     ·     code &amp; entity expansion (codes in query → expanded form)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="320" y="555" width="800" height="60" as="geometry" />
        </mxCell>

        <mxCell id="r_lbl_retrieve" value="5. RETRIEVE" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="20" y="725" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="r_retrieve_container" value="MULTI-SLOT HYBRID RETRIEVAL&#10;per slot: BM25 + Dense → RRF fusion → top-K candidates" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#aaaaaa;dashed=1;verticalAlign=top;fontSize=11;fontStyle=2;fontColor=#666666;align=left;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="140" y="650" width="1160" height="200" as="geometry" />
        </mxCell>
        <mxCell id="r_slot1" value="SLOT 1&#10;In-theme · target&#10;&#10;discipline = Micro&#10;theme ∈ active&#10;top 20" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="160" y="700" width="200" height="140" as="geometry" />
        </mxCell>
        <mxCell id="r_slot2" value="SLOT 2&#10;Cyto analogy&#10;&#10;discipline = Cyto&#10;theme ∈ active&#10;top 10 — adapt, don't copy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="700" width="200" height="140" as="geometry" />
        </mxCell>
        <mxCell id="r_slot3" value="SLOT 3&#10;Adjacent themes&#10;&#10;discipline = Micro&#10;theme ∈ neighbors-by-centroid&#10;top 10" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="600" y="700" width="200" height="140" as="geometry" />
        </mxCell>
        <mxCell id="r_slot4" value="SLOT 4 (cond.)&#10;Jira exemplars&#10;&#10;doc_type = jira_export&#10;only when generate ∧ epic&#10;top 5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;dashed=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="820" y="700" width="200" height="140" as="geometry" />
        </mxCell>
        <mxCell id="r_slot5" value="SLOT 5 (cond.)&#10;Regulatory / standards&#10;&#10;doc_type = regulatory&#10;only on QC / compliance themes&#10;top 3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;dashed=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1040" y="700" width="240" height="140" as="geometry" />
        </mxCell>

        <mxCell id="r_lbl_rerank" value="6. RERANK" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="20" y="885" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="r_rerank_combined" value="Cross-encoder reranker per slot (Cohere Rerank or Claude Haiku) → top-K per slot&#10;Low-score gate: all slots below θ → flag &quot;no relevant content&quot; · broaden &amp; retry · or refuse" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="870" width="1080" height="70" as="geometry" />
        </mxCell>

        <mxCell id="r_lbl_assemble" value="7. ASSEMBLE" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="20" y="975" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="r_assemble_combined" value="ASSEMBLE&#10;dedupe across slots · token-budget trim (drop low-priority slot first) · role-labeled context (PRIMARY · ANALOGY · ADJACENT · EXEMPLAR · REG)&#10;+ 8-theme prior · session context · output schema (epic / story)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="960" width="1080" height="80" as="geometry" />
        </mxCell>

        <mxCell id="r_lbl_output" value="8. OUTPUT" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="20" y="1085" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="r_output_container" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#aaaaaa;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="140" y="1070" width="1160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="r_output_gen" value="→ Generation layer (LLM call · structured output · citations resolved to S3 doc + section + version)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="160" y="1085" width="540" height="50" as="geometry" />
        </mxCell>
        <mxCell id="r_output_tel" value="→ Telemetry (query · intent · slot scores · final context · latency)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="740" y="1085" width="540" height="50" as="geometry" />
        </mxCell>

        <mxCell id="r_e_input_pre" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#444444;strokeWidth=1.5;" edge="1" parent="1" source="r_input_container" target="r_pre_norm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_pre_intent" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#444444;strokeWidth=1.5;" edge="1" parent="1" source="r_pre_norm" target="r_intent_combined">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_intent_decision" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#444444;strokeWidth=1.5;" edge="1" parent="1" source="r_intent_combined" target="r_intent_decision">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_decision_expand" value="proceed" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#444444;strokeWidth=1.5;fontSize=10;" edge="1" parent="1" source="r_intent_decision" target="r_expand_combined">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_expand_retrieve" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#444444;strokeWidth=1.5;" edge="1" parent="1" source="r_expand_combined" target="r_retrieve_container">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_retrieve_rerank" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#444444;strokeWidth=1.5;" edge="1" parent="1" source="r_retrieve_container" target="r_rerank_combined">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_rerank_assemble" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#444444;strokeWidth=1.5;" edge="1" parent="1" source="r_rerank_combined" target="r_assemble_combined">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_assemble_output" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#444444;strokeWidth=1.5;" edge="1" parent="1" source="r_assemble_combined" target="r_output_container">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_decision_clarify" value="low confidence" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#d79b00;strokeWidth=1.5;dashed=1;fontSize=10;fontColor=#d79b00;" edge="1" parent="1" source="r_intent_decision" target="r_branch_clarify">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r_e_decision_session" value="recall / edit" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.7;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;endArrow=classic;strokeColor=#d79b00;strokeWidth=1.5;dashed=1;fontSize=10;fontColor=#d79b00;" edge="1" parent="1" source="r_intent_decision" target="r_branch_session">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="Concepts &amp; AWS" id="concepts-aws">
    <mxGraphModel dx="2200" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="g_title" value="Reference — Concepts &amp; AWS Services" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1100" height="34" as="geometry" />
        </mxCell>
        <mxCell id="g_subtitle" value="Glossary of jargon used across the Ingestion and Retrieval diagrams" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="55" width="1100" height="20" as="geometry" />
        </mxCell>

        <mxCell id="g_sec1" value="ML / RETRIEVAL CONCEPTS" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="105" width="600" height="30" as="geometry" />
        </mxCell>

        <mxCell id="c_dense" value="&lt;b&gt;Dense embedding&lt;/b&gt;&#10;&#10;Text → list of 1024 numbers; similar meaning = similar numbers.&#10;&#10;&lt;i&gt;Ex: 'specimen rejection' &amp;amp; 'what gets bounced at intake' → similar vectors&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="150" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_bm25" value="&lt;b&gt;BM25 / Sparse retrieval&lt;/b&gt;&#10;&#10;Word-by-word scoring; ranks by exact word matches weighted by rarity.&#10;&#10;&lt;i&gt;Ex: catches 'C50.911' or 'Mycobacterium tuberculosis' exactly&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="150" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_hybrid" value="&lt;b&gt;Hybrid retrieval&lt;/b&gt;&#10;&#10;Run BM25 + dense in parallel, merge results.&#10;&#10;&lt;i&gt;Ex: sparse catches 'C50.911', dense catches 'workflow concept'&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="150" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_rrf" value="&lt;b&gt;RRF (Reciprocal Rank Fusion)&lt;/b&gt;&#10;&#10;Merges two ranked lists by RANK, not score. Robust without tuning.&#10;&#10;&lt;i&gt;Ex: rank 2 in BM25 + rank 3 in dense → 1/62 + 1/63&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1160" y="150" width="280" height="140" as="geometry" />
        </mxCell>

        <mxCell id="c_knn" value="&lt;b&gt;Vector index / k-NN&lt;/b&gt;&#10;&#10;Database that returns the K nearest embeddings to a query.&#10;&#10;&lt;i&gt;Ex: OpenSearch returns top 10 nearest chunks in &amp;lt;100ms&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="310" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_cosine" value="&lt;b&gt;Cosine similarity&lt;/b&gt;&#10;&#10;Score 1.0 = identical, 0 = unrelated. Standard yardstick for dense embeddings.&#10;&#10;&lt;i&gt;Ex: query cosine 0.81 with G1 centroid → query is mostly G1 theme&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="310" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_xenc" value="&lt;b&gt;Cross-encoder reranker&lt;/b&gt;&#10;&#10;Slower but more accurate per-pair scorer; the one component that handles negation well.&#10;&#10;&lt;i&gt;Ex: distinguishes 'rejected if NOT refrigerated' from 'accepted'&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="310" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_centroid" value="&lt;b&gt;Centroid (theme centroid)&lt;/b&gt;&#10;&#10;Average embedding representing a group.&#10;&#10;&lt;i&gt;Ex: G1 centroid = average of theme description + a few exemplar phrases for G1&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1160" y="310" width="280" height="140" as="geometry" />
        </mxCell>

        <mxCell id="c_rag" value="&lt;b&gt;RAG&lt;/b&gt;&#10;Retrieval-Augmented Generation&#10;&#10;Retrieve relevant chunks, add to prompt, generate.&#10;&#10;&lt;i&gt;Ex: query → 8 chunks → LLM produces grounded answer with citations&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="470" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_chunking" value="&lt;b&gt;Chunking&lt;/b&gt;&#10;&#10;Split docs into 200–500 token pieces for indexing. Structure-aware = respects sections, tables, numbered steps.&#10;&#10;&lt;i&gt;Ex: a 50-page SOP → ~150 chunks, each retrievable&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="470" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_multilabel" value="&lt;b&gt;Multi-label classification&lt;/b&gt;&#10;&#10;Each item can have multiple labels with confidence scores.&#10;&#10;&lt;i&gt;Ex: 'analyzer QC procedure' → {G5: 0.85, G7: 0.72} (Quality + Instrumentation)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="470" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_ner" value="&lt;b&gt;NER&lt;/b&gt;&#10;Named Entity Recognition&#10;&#10;Extract structured entities from text → faceted metadata.&#10;&#10;&lt;i&gt;Ex: 'M. tuberculosis treated with rifampin' → {organism, drug}&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1160" y="470" width="280" height="140" as="geometry" />
        </mxCell>

        <mxCell id="c_umls" value="&lt;b&gt;UMLS&lt;/b&gt;&#10;Unified Medical Language System&#10;&#10;NIH's master dictionary of clinical codes &amp;amp; terminology.&#10;&#10;&lt;i&gt;Ex: 'C50.911' → 'malignant neoplasm of nipple/areola, right female breast'&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="630" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_phi" value="&lt;b&gt;PHI&lt;/b&gt;&#10;Protected Health Information&#10;&#10;Patient-identifiable info. Must be redacted before indexing.&#10;&#10;&lt;i&gt;Ex: 'Patient John Smith, MRN 123456' → 'Patient [NAME], MRN [MRN]'&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="630" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_idempotent" value="&lt;b&gt;Idempotent&lt;/b&gt;&#10;&#10;Doing twice = doing once; no duplication.&#10;&#10;&lt;i&gt;Ex: re-uploading the same SOP is detected via content hash and skipped&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="630" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="c_dlq" value="&lt;b&gt;DLQ&lt;/b&gt;&#10;Dead-Letter Queue&#10;&#10;Holding pen for failed messages; for human review.&#10;&#10;&lt;i&gt;Ex: encrypted PDF that won't parse → DLQ instead of pipeline crash&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1160" y="630" width="280" height="140" as="geometry" />
        </mxCell>

        <mxCell id="g_sec2" value="AWS SERVICES" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="800" width="600" height="30" as="geometry" />
        </mxCell>

        <mxCell id="a_s3" value="&lt;b&gt;S3&lt;/b&gt;&#10;Simple Storage Service&#10;&#10;Object storage. Where SOPs &amp;amp; original docs live.&#10;&#10;&lt;i&gt;Ex: s3://lab-sops/micro/SOP-MICRO-014_v3.pdf&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="840" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="a_sqs" value="&lt;b&gt;SQS&lt;/b&gt;&#10;Simple Queue Service&#10;&#10;Managed message queue. Buffers ingestion bursts; auto-retry.&#10;&#10;&lt;i&gt;Ex: 50 docs uploaded at once → queued, workers drain&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="840" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="a_dynamo" value="&lt;b&gt;DynamoDB&lt;/b&gt;&#10;&#10;Managed NoSQL DB. Fast key-value / document storage.&#10;&#10;&lt;i&gt;Ex: chunk metadata table — millions of rows, low-latency reads&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="840" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="a_opensearch" value="&lt;b&gt;OpenSearch&lt;/b&gt;&#10;&#10;Search engine; supports BOTH BM25 and k-NN vector search natively.&#10;&#10;&lt;i&gt;One service for sparse + dense indexes&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1160" y="840" width="280" height="140" as="geometry" />
        </mxCell>

        <mxCell id="a_bedrock" value="&lt;b&gt;Bedrock&lt;/b&gt;&#10;&#10;Managed LLM access — Claude, Titan embeddings, Cohere embed/rerank. IAM-authed; data stays in your AWS account.&#10;&#10;&lt;i&gt;Used here for: classification, NER, theme tagging, embeddings, generation&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="1000" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="a_comprehend" value="&lt;b&gt;Comprehend Medical&lt;/b&gt;&#10;&#10;Managed clinical NER + PHI detection. Pre-trained on medical text.&#10;&#10;&lt;i&gt;Ex: extracts organisms, drugs, conditions, PHI from chunks&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="1000" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="a_textract" value="&lt;b&gt;Textract&lt;/b&gt;&#10;&#10;Managed OCR for scanned PDFs and forms. Preserves table layout.&#10;&#10;&lt;i&gt;Ex: reads scanned bench forms; pulls table structure&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="1000" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="a_lambda" value="&lt;b&gt;Lambda&lt;/b&gt;&#10;&#10;Run code on events without managing servers.&#10;&#10;&lt;i&gt;Ex: triggered by S3 PutObject to start ingestion processing&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1160" y="1000" width="280" height="140" as="geometry" />
        </mxCell>

        <mxCell id="a_iam" value="&lt;b&gt;IAM&lt;/b&gt;&#10;Identity and Access Management&#10;&#10;Controls who can do what; least-privilege scoping.&#10;&#10;&lt;i&gt;Ex: only ingestion service can write to chunk-metadata table&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="1160" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="a_kms" value="&lt;b&gt;KMS&lt;/b&gt;&#10;Key Management Service&#10;&#10;Encryption keys you control.&#10;&#10;&lt;i&gt;Ex: all S3 / DynamoDB / OpenSearch encrypted with KMS keys&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="1160" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="a_vpc" value="&lt;b&gt;VPC endpoints&lt;/b&gt;&#10;&#10;Private network paths to AWS services — traffic doesn't traverse the public internet.&#10;&#10;&lt;i&gt;Ex: Bedrock calls stay inside your AWS network&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="1160" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="a_cw" value="&lt;b&gt;CloudWatch&lt;/b&gt;&#10;&#10;Metrics, logs, alarms across all services.&#10;&#10;&lt;i&gt;Ex: alert when OCR failure rate spikes above 5%&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1160" y="1160" width="280" height="140" as="geometry" />
        </mxCell>

        <mxCell id="a_ct" value="&lt;b&gt;CloudTrail&lt;/b&gt;&#10;&#10;Audit log of every AWS API call — who did what, when.&#10;&#10;&lt;i&gt;Ex: records who read which doc when — required for compliance&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="1320" width="280" height="140" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="Ingestion Detail" id="ingestion-detail">
    <mxGraphModel dx="2200" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="id_title" value="Ingestion Pipeline — Stage-by-Stage Detail" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1100" height="34" as="geometry" />
        </mxCell>
        <mxCell id="id_subtitle" value="What each block does, with a Microbiology example" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="55" width="1100" height="20" as="geometry" />
        </mxCell>

        <mxCell id="id_s1" value="&lt;b&gt;1. SOURCES (S3)&lt;/b&gt;&#10;&lt;i&gt;The corpus that feeds the system. New uploads trigger the pipeline.&lt;/i&gt;&#10;&#10;• &lt;b&gt;SOPs / workflow docs&lt;/b&gt; — Authoritative procedure docs &lt;i&gt;(SOP-MICRO-014_Gram-Stain_v3.docx)&lt;/i&gt;&#10;• &lt;b&gt;Call scripts&lt;/b&gt; — Customer-service scripts; tribal knowledge often not written elsewhere&#10;• &lt;b&gt;Transcripts&lt;/b&gt; — SME interviews, training calls (TXT / VTT / SRT)&#10;• &lt;b&gt;Jira exports&lt;/b&gt; — Cyto / Histo Jira CSVs &lt;i&gt;(71 Cyto epics with stories)&lt;/i&gt;&#10;• &lt;b&gt;Regulatory &amp;amp; standards&lt;/b&gt; — CLIA, CAP, CLSI references &lt;i&gt;(CLSI M100 AST breakpoints)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="800" height="240" as="geometry" />
        </mxCell>
        <mxCell id="id_s2" value="&lt;b&gt;2. TRIGGER&lt;/b&gt;&#10;&lt;i&gt;S3 PutObject events buffer through SQS for processing.&lt;/i&gt;&#10;&#10;• &lt;b&gt;S3 PutObject event&lt;/b&gt; — Auto-fires when a file lands &lt;i&gt;(no polling)&lt;/i&gt;&#10;• &lt;b&gt;SQS ingest queue&lt;/b&gt; — Buffers bursts; 3× auto-retry &lt;i&gt;(50 docs at once → queued, workers drain steadily)&lt;/i&gt;&#10;• &lt;b&gt;Content-hash dedupe&lt;/b&gt; — Same content = skip; idempotent re-uploads&#10;• &lt;b&gt;DLQ on retry exhaust&lt;/b&gt; — Failed docs flagged for review &lt;i&gt;(encrypted PDF → DLQ, not pipeline crash)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="860" y="100" width="800" height="240" as="geometry" />
        </mxCell>

        <mxCell id="id_s3" value="&lt;b&gt;3. PARSE&lt;/b&gt;&#10;&lt;i&gt;Format-aware text extraction with code-OCR validation.&lt;/i&gt;&#10;&#10;• &lt;b&gt;Format router&lt;/b&gt; — Detects file type, picks the parser&#10;• &lt;b&gt;PDF (text layer)&lt;/b&gt; — Direct extract from digital PDFs&#10;• &lt;b&gt;Textract OCR&lt;/b&gt; — For scanned PDFs (image-based) &lt;i&gt;(bench form scans)&lt;/i&gt;&#10;• &lt;b&gt;Code-OCR validation&lt;/b&gt; — OCR'd codes checked vs canonical dict &lt;i&gt;(catches 'C5O.91l' typo from OCR confusing O/0, l/1)&lt;/i&gt;&#10;• &lt;b&gt;DOCX, transcripts (TXT/VTT/SRT), CSV/XLSX&lt;/b&gt; — Format-specific parsers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="360" width="800" height="240" as="geometry" />
        </mxCell>
        <mxCell id="id_s4" value="&lt;b&gt;4. DOC PROCESSING (Haiku-assisted)&lt;/b&gt;&#10;&lt;i&gt;Document-level classification, versioning, structure parsing.&lt;/i&gt;&#10;&#10;• &lt;b&gt;Type + discipline classifier&lt;/b&gt; — Haiku assigns {SOP|transcript|jira, Cyto|Micro|Histo} &lt;i&gt;(ambiguous → human review, never silent guess)&lt;/i&gt;&#10;• &lt;b&gt;Version &amp;amp; supersession&lt;/b&gt; — Newer version links to older; old marked inactive (audit chain preserved)&#10;• &lt;b&gt;SOP section parser&lt;/b&gt; — Detects Purpose / Procedure / AC / QC / References sections — section tagged on each chunk&#10;• &lt;b&gt;Metadata extraction&lt;/b&gt; — Author, effective date, doc number, S3 path" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="860" y="360" width="800" height="240" as="geometry" />
        </mxCell>

        <mxCell id="id_s5" value="&lt;b&gt;5. CHUNK&lt;/b&gt;&#10;&lt;i&gt;Structure-aware chunking — preserves document semantics.&lt;/i&gt;&#10;&#10;• &lt;b&gt;Section-bounded&lt;/b&gt; — Chunks never cross sections &lt;i&gt;(Procedure chunks separate from AC chunks)&lt;/i&gt;&#10;• &lt;b&gt;Semantic boundaries&lt;/b&gt; — Splits at sentence / paragraph, not mid-word&#10;• &lt;b&gt;Tables preserved&lt;/b&gt; — SOP tables kept whole when possible &lt;i&gt;('Specimen Rejection Reasons' table = one chunk)&lt;/i&gt;&#10;• &lt;b&gt;Procedure steps grouped&lt;/b&gt; — Numbered steps stay together up to chunk-size limit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="620" width="800" height="240" as="geometry" />
        </mxCell>
        <mxCell id="id_s6" value="&lt;b&gt;6. ENRICH (parallel paths per chunk)&lt;/b&gt;&#10;&lt;i&gt;Each chunk passes through 4 parallel enrichments.&lt;/i&gt;&#10;&#10;• &lt;b&gt;Code expansion&lt;/b&gt; — ICD/CPT/LOINC/SNOMED codes → UMLS lookup; raw + enriched indexed &lt;i&gt;('87186' indexed alongside its name)&lt;/i&gt;&#10;• &lt;b&gt;Clinical NER (Comprehend Medical)&lt;/b&gt; — Extract organisms, drugs, specimens, instruments → faceted metadata&#10;• &lt;b&gt;PHI detection &amp;amp; redaction&lt;/b&gt; — Find names / MRNs / DOBs; redact before indexing (transcripts may contain PHI)&#10;• &lt;b&gt;Theme tagger&lt;/b&gt; — Rules → Haiku fallback; multi-label G1–G8 + unclassified &lt;i&gt;('analyzer QC' → {G5: 0.85, G7: 0.72})&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="860" y="620" width="800" height="240" as="geometry" />
        </mxCell>

        <mxCell id="id_s7" value="&lt;b&gt;7. EMBED — Hybrid embedding&lt;/b&gt;&#10;&lt;i&gt;Each chunk gets BOTH a dense vector AND a sparse representation.&lt;/i&gt;&#10;&#10;• &lt;b&gt;Dense (Bedrock Titan v2 / Cohere)&lt;/b&gt; — 1024-dim semantic vector; catches paraphrase &amp;amp; intent matches&#10;• &lt;b&gt;Sparse (BM25)&lt;/b&gt; — Token-based, raw + enriched; catches exact codes / organism names / regulatory citations&#10;&#10;&lt;i&gt;Why both: dense fails on negation &amp;amp; codes; sparse fails on paraphrase. Combined = robust on clinical content.&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="880" width="800" height="240" as="geometry" />
        </mxCell>
        <mxCell id="id_s8" value="&lt;b&gt;8. STORE&lt;/b&gt;&#10;&lt;i&gt;Five stores — three for retrieval, two for doc-level info + source-of-truth.&lt;/i&gt;&#10;&#10;• &lt;b&gt;Vector index (OpenSearch k-NN)&lt;/b&gt; — Dense embeddings for similarity search&#10;• &lt;b&gt;Sparse index (OpenSearch BM25)&lt;/b&gt; — Tokenized text for exact match&#10;• &lt;b&gt;Chunk metadata (DynamoDB)&lt;/b&gt; — section, themes, entities, version, confidence per chunk&#10;• &lt;b&gt;Doc registry (DynamoDB)&lt;/b&gt; — Doc-level info, supersession, status&#10;• &lt;b&gt;Original docs (S3)&lt;/b&gt; — Source of truth; retrieval citations resolve here" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="860" y="880" width="800" height="240" as="geometry" />
        </mxCell>

        <mxCell id="id_cfg" value="&lt;b&gt;CONFIG / PRIORS&lt;/b&gt;&#10;&lt;i&gt;Refreshable independently — change config without re-uploading the corpus.&lt;/i&gt;&#10;&#10;• &lt;b&gt;8 theme definitions + Micro direction + exemplars&lt;/b&gt; → used by stage 6 (theme tagger)&#10;• &lt;b&gt;Code dictionaries (UMLS · ICD · CPT · LOINC · SNOMED · organism / drug lexicons)&lt;/b&gt; → used by stage 6 (code expansion)&#10;• &lt;b&gt;SOP section taxonomy&lt;/b&gt; → used by stage 4 (section parser)&#10;• &lt;b&gt;8 theme centroid embeddings&lt;/b&gt; — Pre-computed; consumed by RETRIEVAL (intent decode)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;dashed=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="1140" width="800" height="240" as="geometry" />
        </mxCell>
        <mxCell id="id_xcut" value="&lt;b&gt;CROSS-CUTTING&lt;/b&gt;&#10;&lt;i&gt;Operational concerns spanning the entire pipeline.&lt;/i&gt;&#10;&#10;• &lt;b&gt;KMS encryption&lt;/b&gt; — At-rest + in-transit, customer-controlled keys&#10;• &lt;b&gt;DLQ&lt;/b&gt; — Failed parse / OCR / embed flagged for review&#10;• &lt;b&gt;IAM scoping + VPC endpoints&lt;/b&gt; — Least-privilege; Bedrock traffic stays in AWS network&#10;• &lt;b&gt;CloudWatch metrics + alarms&lt;/b&gt; — Per-stage latency, error rate, throughput&#10;• &lt;b&gt;CloudTrail audit log&lt;/b&gt; — Every API call recorded for compliance" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="860" y="1140" width="800" height="240" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="Retrieval Detail" id="retrieval-detail">
    <mxGraphModel dx="2200" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="rd_title" value="Retrieval Pipeline — Stage-by-Stage Detail" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1100" height="34" as="geometry" />
        </mxCell>
        <mxCell id="rd_subtitle" value="What each block does, with a Microbiology example" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="55" width="1100" height="20" as="geometry" />
        </mxCell>

        <mxCell id="rd_s1" value="&lt;b&gt;1. INPUT&lt;/b&gt;&#10;&lt;i&gt;What the system has at the start of each turn.&lt;/i&gt;&#10;&#10;• &lt;b&gt;User query&lt;/b&gt; — What the SME typed &lt;i&gt;('Generate epics for specimen rejection in microbiology')&lt;/i&gt;&#10;• &lt;b&gt;Session state&lt;/b&gt; — Prior artifacts, drafts, refs in this chat session &lt;i&gt;(so 'epic 3' resolves to a real draft)&lt;/i&gt;&#10;• &lt;b&gt;Consumed config&lt;/b&gt; — 8 theme centroids, theme defs, code dictionaries (computed at ingestion time)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="800" height="240" as="geometry" />
        </mxCell>
        <mxCell id="rd_s2" value="&lt;b&gt;2. PRE-PROCESS&lt;/b&gt;&#10;&lt;i&gt;Light text normalization and reference detection.&lt;/i&gt;&#10;&#10;• &lt;b&gt;Normalize&lt;/b&gt; — Trim, fix Unicode&#10;• &lt;b&gt;Language detect&lt;/b&gt; — Flag non-English (POC scope is English)&#10;• &lt;b&gt;Ref extraction&lt;/b&gt; — Detect 'epic 3', '@SOP-MICRO-005', 'the previous one' for later co-reference resolution&#10;&#10;&lt;i&gt;Empty / chitchat queries short-circuit here with a canned response.&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="860" y="100" width="800" height="240" as="geometry" />
        </mxCell>

        <mxCell id="rd_s3" value="&lt;b&gt;3. INTENT DECODE — three components in parallel&lt;/b&gt;&#10;&lt;i&gt;Decode WHAT the user wants, in WHICH theme, at WHAT granularity, in WHICH discipline.&lt;/i&gt;&#10;&#10;• &lt;b&gt;Centroid similarity&lt;/b&gt; — Cosine query vs 8 theme centroids → soft theme distribution &lt;i&gt;(query → {G1: 0.78, G5: 0.21}; cheap, no LLM call)&lt;/i&gt;&#10;• &lt;b&gt;Haiku structured classifier&lt;/b&gt; — Returns &amp;#123;action, themes, discipline, granularity, refs, confidence&amp;#125; — sees centroid distribution as a hint&#10;• &lt;b&gt;Co-reference resolver&lt;/b&gt; — 'epic 3' → session-state ID. Without this, follow-up turns can't act on prior artifacts." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="360" width="800" height="240" as="geometry" />
        </mxCell>
        <mxCell id="rd_dec" value="&lt;b&gt;DECISION GATE&lt;/b&gt;&#10;&lt;i&gt;Confidence ≥ τ AND action ∈ corpus actions?&lt;/i&gt;&#10;&#10;• &lt;b&gt;Proceed&lt;/b&gt; — High confidence, retrieval-relevant action → continue to expand → retrieve → ...&#10;• &lt;b&gt;Clarify (low conf)&lt;/b&gt; — Don't retrieve. Ask the user a disambiguating question. Saves us from confidently-wrong output.&#10;• &lt;b&gt;Recall / edit&lt;/b&gt; — Bypass corpus retrieval; act on session state directly &lt;i&gt;('what did we generate so far?' → session)&lt;/i&gt;&#10;&#10;&lt;i&gt;τ (tau) is tunable; start at ~0.7, refine from telemetry.&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="860" y="360" width="800" height="240" as="geometry" />
        </mxCell>

        <mxCell id="rd_s4" value="&lt;b&gt;4. EXPAND&lt;/b&gt;&#10;&lt;i&gt;Generate alternate phrasings so retrieval doesn't miss synonymous chunks.&lt;/i&gt;&#10;&#10;• &lt;b&gt;Paraphrase + UMLS synonyms&lt;/b&gt; — Multiple query variants &lt;i&gt;('rejection' → 'unacceptable specimens', 'integrity failure', 'specimen NDR')&lt;/i&gt;&#10;• &lt;b&gt;Code &amp;amp; entity expansion&lt;/b&gt; — Codes in query expanded to descriptions &lt;i&gt;('87186' → 'Kirby-Bauer susceptibility studies')&lt;/i&gt;&#10;&#10;&lt;i&gt;Code-only queries can take a sparse-only fast path (no dense expansion needed).&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="620" width="800" height="240" as="geometry" />
        </mxCell>
        <mxCell id="rd_s5" value="&lt;b&gt;5. MULTI-SLOT HYBRID RETRIEVAL&lt;/b&gt;&#10;&lt;i&gt;Five role-labeled slots, each running BM25 + Dense → RRF fusion.&lt;/i&gt;&#10;&#10;• &lt;b&gt;Slot 1 — In-theme target&lt;/b&gt; — discipline=Micro, theme∈active; top 20 (PRIMARY evidence)&#10;• &lt;b&gt;Slot 2 — Cyto analogy&lt;/b&gt; — discipline=Cyto, theme∈active; top 10 (adapt, don't copy)&#10;• &lt;b&gt;Slot 3 — Adjacent themes&lt;/b&gt; — discipline=Micro, neighbor themes; top 10&#10;• &lt;b&gt;Slot 4 (cond.) — Jira exemplars&lt;/b&gt; — Only when generate ∧ epic; top 5 (output shape reference)&#10;• &lt;b&gt;Slot 5 (cond.) — Regulatory&lt;/b&gt; — Only when theme G5 (Quality / Compliance); top 3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="860" y="620" width="800" height="240" as="geometry" />
        </mxCell>

        <mxCell id="rd_s6" value="&lt;b&gt;6. RERANK&lt;/b&gt;&#10;&lt;i&gt;Second-pass scoring + low-score gate against hallucination.&lt;/i&gt;&#10;&#10;• &lt;b&gt;Cross-encoder reranker per slot&lt;/b&gt; — Cohere Rerank or Claude Haiku; trims to top-K per slot&#10;• &lt;b&gt;Why per slot, not global&lt;/b&gt; — Slot roles must be preserved (PRIMARY ≠ ANALOGY ≠ EXEMPLAR)&#10;• &lt;b&gt;Low-score gate (θ)&lt;/b&gt; — All slots below θ → flag 'no relevant content', broaden &amp;amp; retry, or refuse &lt;i&gt;(antidote to confident hallucination on out-of-corpus queries)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="880" width="800" height="240" as="geometry" />
        </mxCell>
        <mxCell id="rd_s7" value="&lt;b&gt;7. ASSEMBLE&lt;/b&gt;&#10;&lt;i&gt;Package retrieved chunks into a final prompt for the generator.&lt;/i&gt;&#10;&#10;• &lt;b&gt;Dedupe across slots&lt;/b&gt; — Multi-slot hits keep best score, note multi-slot membership&#10;• &lt;b&gt;Token-budget trim&lt;/b&gt; — Drop low-priority slot first (5, then 4, then 3) before trimming within slots&#10;• &lt;b&gt;Role-labeled context&lt;/b&gt; — Chunks enter prompt as PRIMARY / ANALOGY / ADJACENT / EXEMPLAR / REG&#10;• &lt;b&gt;+ 8-theme prior + session context + output schema (epic / story)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="860" y="880" width="800" height="240" as="geometry" />
        </mxCell>

        <mxCell id="rd_s8" value="&lt;b&gt;8. OUTPUT&lt;/b&gt;&#10;&lt;i&gt;Generation call + telemetry capture.&lt;/i&gt;&#10;&#10;• &lt;b&gt;→ Generation layer&lt;/b&gt; — Bedrock Claude with structured-output schema; each artifact carries citations to S3 doc + section + version&#10;• &lt;b&gt;→ Telemetry&lt;/b&gt; — Query, intent decode, slot scores, final context, latency &lt;i&gt;(eval signal — without this, we can't improve retrieval)&lt;/i&gt;&#10;&#10;&lt;i&gt;SME reviews → accepts / edits / rejects → next turn iterates.&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="1140" width="800" height="240" as="geometry" />
        </mxCell>
        <mxCell id="rd_example" value="&lt;b&gt;WORKED EXAMPLE&lt;/b&gt;&#10;&lt;i&gt;Query: 'Generate epics for specimen rejection in microbiology'&lt;/i&gt;&#10;&#10;1. Pre-process → English, no session refs&#10;2. Centroid → {G1: 0.81, G5: 0.18}&#10;3. Haiku → {action: generate, themes: [G1, G5], discipline: Micro, granularity: epic, conf: 0.91}&#10;4. Decision → proceed (conf &amp;gt; τ)&#10;5. Expand → 'rejection criteria', 'integrity failure', 'unacceptable specimens'&#10;6. Multi-slot retrieve → S1 Micro SOPs · S2 Cyto epic · S3 G2 adjacent · S4 exemplars · S5 CLSI&#10;7. Rerank → top-K trimmed; scores OK&#10;8. Assemble → role-labeled context + 8-theme prior + schema&#10;9. Generate → 2–4 epics in G1, each with stories + citations&#10;10. Telemetry logged for eval" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="860" y="1140" width="800" height="240" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
