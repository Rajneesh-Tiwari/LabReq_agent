        <mxCell id="iio_r4_out" value="&lt;i&gt;[OUTPUT]&lt;/i&gt;&#10;&#10;Doc registry entry:&#10;  doc_id:        doc_micro_014_v3_abc12&#10;  type:          SOP&#10;  discipline:    Microbiology&#10;  version:       v3&#10;  status:        active&#10;  supersedes:    doc_micro_014_v2_xyz98&#10;  effective:     2024-08-15&#10;  author:        J. Smith&#10;&#10;Section map:&#10;  Purpose:[200,450]  Procedure:[721,2400]  AC:[2401,3100]&#10;  QC:[3101,3650]     References:[3651,3900]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=9;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;spacingRight=10;fontFamily=Courier New;" vertex="1" parent="1">
